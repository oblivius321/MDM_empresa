# ===== ELION MDM - CONFIGURAÇÃO DE AMBIENTE =====

# ===== BANCO DE DADOS =====
DB_USER=postgres
DB_PASSWORD=Sherlock314
DB_NAME=mdm_project
DATABASE_URL=postgresql+asyncpg://postgres:Sherlock314@localhost:5432/mdm_project

# ===== SEGURANÇA =====
# IMPORTANTE: Mudar em produção! Gere uma chave aleatória robusta.
# Ex: run `python -c "import secrets; print(secrets.token_urlsafe(32))"`
SECRET_KEY=dev-secret-key-change-in-production

# ===== MODO =====
DEBUG=True
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ===== APLICAÇÃO =====
REQUEST_TIMEOUT=30
DEVICE_CHECKIN_TIMEOUT=300

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,http://localhost:8081

# ===== URLS =====
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8000/api
ANDROID_API_BASE_URL=http://localhost:8000/api
