# ===============================================
# Elion MDM – PRODUÇÃO
# Copie para ".env" no servidor VPS
# ===============================================

# ── PostgreSQL (gere senha forte!) ────────
DB_USER=mdm_admin
DB_PASSWORD=GERE_SENHA_FORTE_AQUI
DB_NAME=elion_mdm
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://mdm_admin:GERE_SENHA_FORTE_AQUI@postgres:5432/elion_mdm

# ── Segurança ─────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GERE_CHAVE_SEGURA_AQUI
BOOTSTRAP_SECRET=GERE_BOOTSTRAP_SEGURO_AQUI
DEFAULT_ADMIN_PASSWORD=TroquePorSenhaForte123!

# ── Ambiente ──────────────────────────────
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=WARNING

# ── URLs & CORS (ALTERAR para seus domínios!) ──
API_URL=https://api.sua-empresa.com
FRONTEND_URL=https://painel.sua-empresa.com
ALLOWED_ORIGINS=https://painel.sua-empresa.com

# ⏱️ Timeouts
DEVICE_CHECKIN_TIMEOUT=150
REQUEST_TIMEOUT=30
