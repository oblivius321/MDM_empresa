# рҹ—„пёҸ PostgreSQL (gere senha forte!)
DB_USER=mdm_admin
DB_PASSWORD=GERE_SENHA_FORTE_AQUI
DB_NAME=elion_mdm
DATABASE_URL=postgresql+asyncpg://mdm_admin:CHANGE_ME@postgres:5432/elion_mdm

# рҹ”’ SeguranГ§a (gere com: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=GERE_CHAVE_SEGURA_AQUI

# рҹ’» Modo
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=WARNING

# рҹҢҚ URLs (ALTERAR para seus domГӯnios!)
API_URL=https://api.sua-empresa.com
FRONTEND_URL=https://painel.sua-empresa.com
ALLOWED_ORIGINS=https://painel.sua-empresa.com

# вҸұпёҸ Timeouts
DEVICE_CHECKIN_TIMEOUT=150
REQUEST_TIMEOUT=30
