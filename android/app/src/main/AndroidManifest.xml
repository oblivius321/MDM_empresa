<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ─── Permissões ──────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE"/>
    <!-- Telemetria: GPS e localização -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.BATTERY_STATS" />

    <!-- ─── Aplicação ───────────────────────────────────────────────────── -->
        <application
            android:name=".ElionMDMApp"
            android:allowBackup="false"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.ElionMDM">

        <!-- ─── Kiosk Launcher (HOME) ──────────────────────────────── -->
        <activity
            android:name=".launcher.KioskLauncherActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.HOME"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>

        <!-- ─── Admin Login ────────────────────────────────────────── -->
        <activity
            android:name=".admin.AdminLoginActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.ElionMDM"/>

        <!-- ─── Admin Panel ────────────────────────────────────────── -->
        <activity
            android:name=".admin.AdminPanelActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/Theme.ElionMDM"/>

        <!-- ─── App Selection ──────────────────────────────────────── -->
        <activity
            android:name=".launcher.AppSelectionActivity"
            android:exported="false"
            android:theme="@style/Theme.ElionMDM" />


        <!-- ─── Enrollment MainActivity (kept for technician setup) ── -->
        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Android 12+ admin-integrated provisioning callbacks -->
        <activity
            android:name=".provisioning.ProvisioningModeActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:noHistory="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:theme="@style/Theme.ElionMDM">
            <intent-filter>
                <action android:name="android.app.action.GET_PROVISIONING_MODE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".provisioning.AdminPolicyComplianceActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:noHistory="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:theme="@style/Theme.ElionMDM">
            <intent-filter>
                <action android:name="android.app.action.ADMIN_POLICY_COMPLIANCE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.app.action.PROVISIONING_SUCCESSFUL" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- ─── Admin Receiver (DPC Entry Point) ───────────────────────── -->
        <receiver
            android:name=".AdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_receiver" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- ─── Boot Receiver ─────────────────────────────────────── -->
        <receiver
            android:name=".system.BootReceiver"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
            </intent-filter>
        </receiver>

        <!-- ─── MDM Foreground Service ────────────────────────────── -->
        <service
            android:name=".services.MDMForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_TYPE"
                      android:value="MDM agent for telemetry and command processing"/>
        </service>

    </application>
</manifest>
