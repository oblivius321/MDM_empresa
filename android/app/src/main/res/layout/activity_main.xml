<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tv_dev_mode_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@color/error"
                android:gravity="center"
                android:padding="10dp"
                android:text="DEV MODE"
                android:textColor="@color/on_primary"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/enrollment_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Enrollment"
                    android:textColor="@color/on_background"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:text="Configure o backend e o token bootstrap do dispositivo."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/et_backend_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:autofillHints=""
                    android:background="@color/surface_overlay"
                    android:hint="Backend URL"
                    android:importantForAutofill="no"
                    android:inputType="textUri"
                    android:minHeight="52dp"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="12dp"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/text_muted"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/et_bootstrap_secret"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:autofillHints=""
                    android:background="@color/surface_overlay"
                    android:hint="Bootstrap Token"
                    android:importantForAutofill="no"
                    android:inputType="textPassword"
                    android:minHeight="52dp"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="12dp"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/text_muted"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btn_enroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:text="Enroll Device"
                    android:textAllCaps="false"
                    android:textColor="@color/on_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_enroll_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/error"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/status_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_device_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_last_sync"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_device_owner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_camera"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_kiosk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_allowed_apps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_policy_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_backend_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_controller_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/success"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btn_manage_apps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:minHeight="52dp"
                    android:text="Manage Apps"
                    android:textAllCaps="false"
                    android:textColor="@color/on_primary"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_enable_kiosk"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:minHeight="52dp"
                    android:text="Enable Kiosk Mode"
                    android:textAllCaps="false"
                    android:textColor="@color/on_primary"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_refresh"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:minHeight="52dp"
                    android:text="Refresh"
                    android:textAllCaps="false"
                    android:textColor="@color/on_primary"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#660D1117"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />
    </FrameLayout>

</FrameLayout>
