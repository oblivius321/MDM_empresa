<?xml version="1.0" encoding="utf-8"?>
<!-- activity_admin_login.xml — Tela de login do administrador -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0D1117">

    <!-- Logo -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="Elion Logo"
        android:layout_marginBottom="8dp"/>

    <!-- Título -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Elion Admin"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Autenticação necessária"
        android:textColor="#8B949E"
        android:textSize="13sp"
        android:layout_marginBottom="32dp"/>

    <!-- Card de login -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#161B22">

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Corporativo"
            android:textColor="#C9D1D9"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="textEmailAddress"
            android:hint="admin@empresa.com"
            android:textColor="#C9D1D9"
            android:textColorHint="#484F58"
            android:background="#0D1117"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"
            android:importantForAutofill="no"/>

        <!-- Senha -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Senha"
            android:textColor="#C9D1D9"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="textPassword"
            android:hint="••••••••"
            android:textColor="#C9D1D9"
            android:textColorHint="#484F58"
            android:background="#0D1117"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"
            android:importantForAutofill="no"/>

        <!-- Mensagem de erro / tentativas -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F85149"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Tentativas restantes -->
        <TextView
            android:id="@+id/tv_attempts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#8B949E"
            android:textSize="11sp"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Botão Login -->
        <Button
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Entrar"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:backgroundTint="#238636"
            android:layout_marginTop="8dp"/>

        <!-- ProgressBar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Botão Voltar -->
    <TextView
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Voltar ao Kiosk"
        android:textColor="#58A6FF"
        android:textSize="13sp"
        android:layout_marginTop="24dp"
        android:padding="8dp"/>
</LinearLayout>
