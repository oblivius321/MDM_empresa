# =======================================================
# 🧪 ELION MDM - REFERÊNCIA DE DESENVOLVIMENTO
# Copie este arquivo para ".env" na raiz para testes locais.
# =======================================================

# ⚠️ ESTE ARQUIVO FOI MODIFICADO POR SEGURANÇA - ROTAÇÃO DE CREDENCIAIS
# 🗄️ Credenciais do PostgreSQL (APENAS PARA DESENVOLVIMENTO)
DB_USER=postgres
DB_PASSWORD=dev_password_change_me
DB_NAME=mdm_project

# Acesso pelo Docker (Serviços acessam Serviços pelo Nome do Host)
DATABASE_URL=postgresql+asyncpg://postgres:dev_password_change_me@postgres:5432/mdm_project

# 🔒 Segurança da API (FastAPI)
# ⚠️ NÃO REUTILIZE ESTE SECRET EM PRODUÇÃO
SECRET_KEY=dev-secret-key-only-for-local-development-12345678

# 🔐 Bootstrap Secret para Enroll Seguro de Dispositivos (DEV ONLY)
BOOTSTRAP_SECRET=dev-bootstrap-secret-12345678

# 👤 Senha padrão do Administrador Root a ser gerado
DEFAULT_ADMIN_PASSWORD=AdminSenhaForte123!

# 💻 Modo e Comportamento
DEBUG=True
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# 🌍 Portas, Endereços e CORS
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,http://localhost:8081

# 📱 Dispositivos 
DEVICE_CHECKIN_TIMEOUT=300
ANDROID_API_BASE_URL=http://localhost:8000/api
VITE_API_URL=http://localhost:8000/api

# ⏱️ Timeouts
REQUEST_TIMEOUT=30
