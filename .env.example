# ===============================================
# Elion MDM – Environment Variables
# Copie para ".env" e preencha os valores
# ===============================================

# ── PostgreSQL ─────────────────────────────
DB_USER=postgres
DB_PASSWORD=TROQUE_PARA_SENHA_FORTE
DB_NAME=mdm_project
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:TROQUE_PARA_SENHA_FORTE@postgres:5432/mdm_project

# ── Segurança ─────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GERE_UMA_CHAVE_SEGURA_AQUI
# Senha para enrollment de dispositivos Android
BOOTSTRAP_SECRET=GERE_UMA_CHAVE_BOOTSTRAP_AQUI
# Senha do primeiro admin criado via create_admin.py
DEFAULT_ADMIN_PASSWORD=TroquePorSenhaForte123!

# ── Ambiente ──────────────────────────────
# development | production
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=DEBUG

# ── URLs & CORS ───────────────────────────
API_URL=http://192.168.25.227:8200
FRONTEND_URL=http://192.168.25.227:3000
# Separe múltiplas origins por vírgula
ALLOWED_ORIGINS=http://192.168.25.227:3000,http://192.168.25.227:5173

# ── Timeouts ──────────────────────────────
DEVICE_CHECKIN_TIMEOUT=300
REQUEST_TIMEOUT=30

# ── Android Management API (DPC oficial Google) ──
# NUNCA cole o JSON da service account neste arquivo.
ANDROID_MANAGEMENT_PROJECT_ID=mdm-projeto2
ANDROID_MANAGEMENT_SERVICE_ACCOUNT_FILE=secrets/android-management-service-account.json
# Opcional: pacote privado publicado no Managed Google Play para modo kiosk.
ANDROID_MANAGEMENT_KIOSK_PACKAGE=
